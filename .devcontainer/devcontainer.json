{
  "containerEnv": {
    "ASTRO_TELEMETRY_DISABLED": "1"
  },
  "customizations": {
    // Configure JetBrains IDE-specific properties
    "jetbrains": {
      "backend": "IntelliJ",
      "plugins": [
        "org.jetbrains.plugins.astro",
        "mdx.js"
        // A set of plugin IDs.
        // Plugin ID can be found on the corresponding plugin’s page at https://plugins.jetbrains.com.
      ],
      "settings": {
        "com.intellij:app:BuiltInServerOptions.builtInServerPort": 54437,
        "com.intellij:app:EditorSettings.is_ensure_newline_at_eof": true,
        "com.intellij:app:HttpConfigurable.use_proxy_pac": true,
        "org.jetbrains.plugins.terminal:app:TerminalOptionsProvider.myShellPath": "/bin/zsh"
        // IDE settings can be added via “Show context actions”|“Add currently modified settings from IDE”.
        // A complete list of supported settings is also available through auto-completion
      }
    },
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "cucumberopen.cucumber-official",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-containers",
        "ms-playwright.playwright",
        "unifiedjs.vscode-mdx",
        "vitest.explorer"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainer-community/devcontainer-features/jq:1": {},
    "ghcr.io/devcontainers-extra/features/curl-apt-get:1": {},
    "ghcr.io/devcontainers/features/git:1.3.5": {},
    "ghcr.io/devcontainers/features/node:2.1.0": {
      "version": 24
    }
  },
  "forwardPorts": [
    4321, // astro dev-server
    51204 // vitest-ui
  ],
  "image": "ubuntu:24.04",
  "name": "bbon-dev-container-node24",
  "postCreateCommand": "npm ci && npx playwright install --with-deps chromium"
}
