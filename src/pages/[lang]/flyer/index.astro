---
import {
  SupportedLanguages,
  type LanguagesValue,
} from '../../../model/languages';
import { getCollection } from 'astro:content';
import { useUiTranslation } from '../../../content/use-ui-translation.ts';
import { getTranslationsUrlsForPath } from '../../../util/get-translations-url';
import { getCanonicalUrlToFlyer } from '../../../util/get-canonical-url';
import { mapStaticPathsForStandalone } from '../../../util/map-static-paths-for-standalone';
import type { StandaloneContentProps } from '../../../model/standalone-collections';

import CardLink from '../../../components/design/CardLink.astro';
import H1 from '../../../components/design/H1.astro';
import LanguageSwitcher from '../../../components/design/LanguageSwitcher.astro';
import MoreInfoStack from '../../../components/MoreInfoStack.astro';
import OverviewLayout from '../../../layouts/OverviewLayout.astro';
import Stack from '../../../components/design/Stack.astro';

interface Props {
  lang: LanguagesValue;
}

export async function getStaticPaths() {
  return Object.values(SupportedLanguages).map((lang) => {
    return {
      params: { lang },
      props: { lang },
    };
  });
}

const { lang } = Astro.props;

const sortedFlyers: StandaloneContentProps<'flyers'>[] =
  mapStaticPathsForStandalone<'flyers'>(await getCollection('flyers')).sort(
    (a, b) =>
      (a.props.entry.data?.index || 0) - (b.props.entry.data?.index || 0),
  );

const translationSlugs = await getTranslationsUrlsForPath(lang, 'flyer');
---

<OverviewLayout
  lang={lang}
  title=`${await useUiTranslation('meta.title', lang)} | ${await useUiTranslation('meta.subtitle', lang)}`
  translationSlugs={translationSlugs}
>
  <LanguageSwitcher
    lang={lang}
    translationSlugs={translationSlugs}
  />
  <Stack>
    <H1 slot="heading">{useUiTranslation('meta.allFlyers', lang)}</H1>
    {
      sortedFlyers
        .filter((flyer) => flyer.params.lang === lang)
        .map(async (flyer) => (
          <CardLink
            lang={lang}
            href={await getCanonicalUrlToFlyer(flyer.props.entry, lang)}
          >
            {flyer.props.entry.data.title}
          </CardLink>
        ))
    }
  </Stack>

  <MoreInfoStack
    lang={lang}
    showKit={true}
  />
</OverviewLayout>
