---
import { type CollectionEntry, getCollection } from 'astro:content';
import { type LanguagesValue } from '../../model/languages';
import type { MarkdownCollections } from '../../model/standalone-collections';

import MarkdownEntry from './MarkdownEntry.astro';
import NotFoundError from '../design/NotFoundError.astro';
import NoteMachineTranslation from '../design/NoteMachineTranslation.astro';
import NoteOnlyFallbackTranslation from '../design/NoteOnlyFallbackTranslation.astro';

export interface Props {
  identifier: string;
  lang?: LanguagesValue;
  collection?: MarkdownCollections;
  recursive?: boolean;
  isRootLevelContent?: boolean;
}

const {
  identifier,
  lang = Astro.locals.lang,
  collection = 'blocks',
  recursive = true,
  isRootLevelContent = false,
} = Astro.props;

const blockEntries = await getCollection(collection, (block) => {
  return block.slug === `${identifier}/${lang}`;
});

let blockEntry = blockEntries[0] as CollectionEntry<MarkdownCollections>;

if (isRootLevelContent) {
  Astro.locals.levelShift = 0;
}

let isFallback = false;
const fallbackToLang = blockEntry?.data?.fallbackToLang;

if (fallbackToLang !== lang) {
  const fallbackEntries = await getCollection(collection, (block) => {
    return block.slug === `${identifier}/${fallbackToLang}`;
  });

  if (fallbackEntries.length > 0) {
    blockEntry = fallbackEntries[0];
    isFallback = true;
  }
}
---

{isFallback && <NoteOnlyFallbackTranslation entry={blockEntry} />}

{
  blockEntry ? (
    <NoteMachineTranslation
      entry={blockEntry}
      isRootLevelContent={isRootLevelContent}
    >
      <MarkdownEntry
        rendered={blockEntry.render()}
        recursive={recursive}
      />
    </NoteMachineTranslation>
  ) : (
    recursive && (
      <NotFoundError context={`${collection}/${identifier}/${lang}`} />
    )
  )
}
