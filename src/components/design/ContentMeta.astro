---
import type { CollectionEntry } from 'astro:content';

import LanguageChip from './LanguageChip.astro';
import Timestamp from './Timestamp.astro';
import type { StandaloneCollections } from '../../model/standalone-collections';
import { DEFAULT_LANG, type LanguagesValue } from '../../model/languages';

interface Props {
  entry: CollectionEntry<StandaloneCollections>;
  lang?: LanguagesValue;
  isFallback?: boolean;
}

const { entry, lang = entry.data.lang, isFallback = false } = Astro.props;
---

<p>
  <LanguageChip
    lang={entry.data.lang}
    currentLang={isFallback ? lang : DEFAULT_LANG}
  />
  –
  <Timestamp
    lang={lang}
    lastChecked={entry.data.lastChecked}
  />
</p>
